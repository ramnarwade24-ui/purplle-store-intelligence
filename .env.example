# API
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://api:8000

# Storage
SQLITE_PATH=/data/storeintel.db

# Logging
LOG_LEVEL=INFO
LOG_JSON=true

# Processor
PROCESSOR_BATCH_SIZE=200
PROCESSOR_FRAME_STRIDE=3
PROCESSOR_POSITION_EVENT_EVERY_N_FRAMES=5
PROCESSOR_TRACK_BUFFER_FRAMES=30

# Models
YOLO_MODEL=yolov8n.pt
YOLO_CONF=0.25
